# Copy to .env and set values. Vite exposes only variables prefixed with VITE_.

# Required in production builds (npm run build). Dev falls back to http://localhost:8080 if unset.
VITE_API_BASE_URL=https://your-api.example.com

# EmailJS (Contact page) — get IDs from https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
# Optional: recipient override for template (if your template uses to_email)
VITE_EMAILJS_TO_EMAIL=
